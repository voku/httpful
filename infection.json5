{
    "$schema": "./vendor/infection/infection/resources/schema.json",
    "source": {
        "directories": [
            "src"
        ]
    },
    "threads": "max",
    "timeout": 60,
    "minMsi": 99.5,
    "minCoveredMsi": 99.5,
    "maxTimeouts": 0,
    "timeoutsAsEscaped": true,
    "testFramework": "phpunit",
    "phpUnit": {
        "configDir": "."
    },
    "phpStan": {
        "configDir": "."
    },
    "testFrameworkOptions": "--do-not-cache-result",
    "staticAnalysisTool": "phpstan",
    "mutators": {
        "@default": true,
        "MethodCallRemoval": {
            "ignoreSourceCodeByRegex": [
                "\\$curl->setOpt\\(\\\\CURLOPT_NOSIGNAL, true\\);",
                "\\$curl->setOpt\\(\\\\CURLOPT_SSL_VERIFYHOST, \\$verifyValue\\);",
                "\\$curl->setOpt\\(\\\\CURLOPT_RETURNTRANSFER, true\\);",
                "\\$this->disableAutoParsing\\(\\);"
            ]
        },
        "UnwrapArrayValues": {
            "ignoreSourceCodeByRegex": [
                "\\$payload_first = \\\\array_values\\(\\$payload\\)\\[0\\]"
            ]
        }
    }
}
